{
  "name": "openalgo-charts",
  "version": "0.1.0",
  "description": "From-scratch, dependency-free canvas charting engine for OpenAlgo: professional-grade interactive rendering plus advanced on-chart trading.",
  "license": "Apache-2.0",
  "type": "module",
  "module": "dist/openalgo-charts.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/openalgo-charts.mjs"
    },
    "./trade": {
      "types": "./dist/trade/index.d.ts",
      "import": "./dist/openalgo-charts.trade.mjs"
    },
    "./transform": {
      "types": "./dist/transform/index.d.ts",
      "import": "./dist/openalgo-charts.transform.mjs"
    },
    "./profile": {
      "types": "./dist/profile/index.d.ts",
      "import": "./dist/openalgo-charts.profile.mjs"
    }
  },
  "files": ["dist/**"],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "docs": "typedoc",
    "verify": "npm run typecheck && npm run test && npm run build && npm run size"
  },
  "engines": { "node": ">=20" },
  "devDependencies": {
    "@rollup/plugin-typescript": "12.1.2",
    "@rollup/plugin-terser": "0.4.4",
    "@size-limit/file": "11.1.6",
    "rimraf": "6.0.1",
    "rollup": "4.30.1",
    "rollup-plugin-dts": "6.1.1",
    "size-limit": "11.1.6",
    "tslib": "2.8.1",
    "typedoc": "0.27.6",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
